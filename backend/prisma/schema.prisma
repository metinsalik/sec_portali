generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  username        String         @id
  fullName        String
  email           String?
  phone           String?
  department      String?
  title           String?
  isActive        Boolean        @default(true)
  employmentType  String?
  osgbName        String?
  roles           UserRole[]
  facilities      UserFacility[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  users     UserRole[]
  createdAt DateTime   @default(now())
}

model UserRole {
  username String
  roleId   Int
  user     User     @relation(fields: [username], references: [username])
  role     Role     @relation(fields: [roleId], references: [id])

  @@id([username, roleId])
}

model Facility {
  id               String             @id
  name             String
  shortName        String?
  type             String?            // "Hastane", "Ofis", "Depo", etc.
  city             String?
  district         String?
  fullAddress      String?
  phone            String?
  email            String?
  website          String?
  commercialTitle  String?
  taxOffice        String?
  taxNumber        String?
  sgkNumber        String?
  naceCode         String?
  dangerClass      String             @default("Az Tehlikeli") // "Çok Tehlikeli" | "Tehlikeli" | "Az Tehlikeli"
  employeeCount    Int                @default(0)
  employeeCountHistory EmployeeCountHistory[]
  isActive         Boolean            @default(true)
  buildings        FacilityBuilding[]
  users            UserFacility[]
  assignments      Assignment[]
  activityLogs     ActivityLog[]
  monthlyHrData    MonthlyHRData[]
  monthlyAccident  MonthlyAccidentData[]
  reconciliations  Reconciliation[]
  notebookEntries  NotebookEntry[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id])
  username   String
  action     String   // e.g., "Çalışan Sayısı Güncellendi", "Yeni Atama Yapıldı"
  details    String?
  createdAt  DateTime @default(now())
}

model EmployeeCountHistory {
  id            Int      @id @default(autoincrement())
  facilityId    String
  facility      Facility @relation(fields: [facilityId], references: [id])
  count         Int
  effectiveDate DateTime
  createdAt     DateTime @default(now())
}

model FacilityBuilding {
  id               Int      @id @default(autoincrement())
  facilityId       String
  facility         Facility @relation(fields: [facilityId], references: [id])
  name             String
  constructionYear Int?
  buildingHeight   Float?
  structureHeight  Float?
  buildingFloors   Int?
  structureFloors  Int?
  closedArea       Float?
  parkingArea      Float?
  gardenArea       Float?
  bedCapacity      Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserFacility {
  username   String
  facilityId String
  user       User     @relation(fields: [username], references: [username])
  facility   Facility @relation(fields: [facilityId], references: [id])

  @@id([username, facilityId])
}

model Professional {
  id              Int          @id @default(autoincrement())
  fullName        String
  employmentType  String
  osgbName        String?
  titleClass      String
  certificateNo   String?
  certificateDate DateTime?
  phone           String?
  email           String?
  unitPrice       Float?
  username        String?      // Link to User.username
  isActive        Boolean      @default(true)
  assignments     Assignment[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model EmployerRepresentative {
  id          Int          @id @default(autoincrement())
  fullName    String
  title       String?
  phone       String?
  email       String?
  username    String?      // Link to User.username
  isActive    Boolean      @default(true)
  appointments Assignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model OSGBCompany {
  id              Int              @id @default(autoincrement())
  name            String
  contact         String?
  phone           String?
  email           String?
  city            String?
  district        String?
  isActive        Boolean          @default(true)
  reconciliations Reconciliation[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Reconciliation {
  id               Int         @id @default(autoincrement())
  facilityId       String
  facility         Facility    @relation(fields: [facilityId], references: [id])
  osgbCompanyId    Int
  osgbCompany      OSGBCompany @relation(fields: [osgbCompanyId], references: [id])
  month            String      // "2026-04"
  calculatedAmount Float?      // Sistem tarafından hesaplanan tutar
  invoiceAmount    Float?      // OSGB'den gelen fatura tutarı
  difference       Float?      // Fark (Hesaplanan - Fatura)
  calculationDetails Json?     // Detaylı hesaplama dökümü (her profesyonel için)
  amount           Float?      // Toplam (genellikle onaylanan tutar)
  note             String?
  status           String      @default("Beklemede") // "Beklemede" | "Onaylandı" | "Reddedildi" | "Uyuşmazlık"
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([facilityId, osgbCompanyId, month])
}

model Assignment {
  id              Int                     @id @default(autoincrement())
  facilityId      String
  facility        Facility                @relation(fields: [facilityId], references: [id])
  professionalId  Int?
  professional    Professional?           @relation(fields: [professionalId], references: [id])
  employerRepId   Int?
  employerRep     EmployerRepresentative? @relation(fields: [employerRepId], references: [id])
  type            String
  durationMinutes Int
  isFullTime      Boolean                 @default(false)
  startDate       DateTime
  endDate         DateTime?
  status          String
  costType        String?
  unitPrice       Float?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model SystemSettings {
  id                Int      @id @default(autoincrement())
  year              Int      @unique
  seriousAccidentDays Int    @default(4)
  includeSaturday     Boolean  @default(true)
  dailyWorkHours      Float    @default(7.5)
  monthlyWorkDays     Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model MonthlyHRData {
  id                 Int      @id @default(autoincrement())
  facilityId         String
  facility           Facility @relation(fields: [facilityId], references: [id])
  month              String
  mainEmployerData   Json
  subContractorData  Json
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([facilityId, month])
}

model MonthlyAccidentData {
  id                 Int      @id @default(autoincrement())
  facilityId         String
  facility           Facility @relation(fields: [facilityId], references: [id])
  month              String
  mainEmployerData   Json
  subContractorData  Json
  internData         Json
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([facilityId, month])
}

model Category {
  id            Int             @id @default(autoincrement())
  name          String
  subCategories SubCategory[]
  notebookEntries NotebookEntry[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model SubCategory {
  id         Int      @id @default(autoincrement())
  name       String
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
  notebookEntries NotebookEntry[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String
  notebookEntries NotebookEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotebookEntry {
  id              Int      @id @default(autoincrement())
  facilityId      String
  facility        Facility @relation(fields: [facilityId], references: [id])
  year            Int
  date            DateTime
  authorType      String   // "DOKTOR" | "UZMAN"
  authorName      String
  content         String   @db.Text
  categoryId      Int
  category        Category @relation(fields: [categoryId], references: [id])
  subCategoryId   Int?
  subCategory     SubCategory? @relation(fields: [subCategoryId], references: [id])
  departmentId    Int
  department      Department @relation(fields: [departmentId], references: [id])
  documentUrl     String?  // PNG, JPEG, PDF path
  status          String   @default("Eksik") // "Eksik" | "Tamamlandı"
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([facilityId, year])
}


model SmtpSettings {
  id        Int      @id @default(1) // Always use ID 1 for system-wide settings
  host      String
  port      Int
  user      String
  pass      String
  secure    Boolean  @default(false)
  fromEmail String
  fromName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   // "info", "warning", "success", "error"
  module    String   @default("SYSTEM") // e.g., "OPERATIONS", "FACILITIES", "SYSTEM"
  targetRole String? // Specific role to notify, or null for all
  username  String?  // Specific user to notify, or null for all
  isRead    Boolean  @default(false)
  link      String?  // Optional link to redirect
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationTemplate {
  id          Int      @id @default(autoincrement())
  code        String   @unique // e.g., "NEW_ACCIDENT_REPORT"
  name        String   // Human readable name
  module      String   // e.g., "OPERATIONS", "FACILITIES"
  subject     String
  body        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotificationConfig {
  id           Int      @id @default(autoincrement())
  code         String   @unique // Matches NotificationTemplate.code
  module       String
  description  String?
  emailEnabled Boolean  @default(true)
  appEnabled   Boolean  @default(true)
  priority     String   @default("normal") // "low", "normal", "high", "critical"
  updatedAt    DateTime @updatedAt
}

model AdministrativeFine {
  id                            Int      @id @default(autoincrement())
  year                          Int      @unique
  specialistAndPhysicianVery    Float
  specialistAndPhysicianDanger  Float
  specialistAndPhysicianLess    Float
  dspVeryDangerous              Float
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model ReportTemplate {
  id            Int      @id @default(autoincrement())
  code          String   // e.g., "MONTHLY_ACCIDENT_REPORT"
  name          String
  version       Int      @default(1)
  isActive      Boolean  @default(false)
  isArchived    Boolean  @default(false)
  module        String   // "OPERATIONS" | "FACILITIES" | "PANEL"
  
  // Quality Metadata
  documentNo    String?
  revisionNo    String?
  releaseDate   DateTime?
  
  // Design
  content       Json     // Tiptap JSON content
  orientation   String   @default("PORTRAIT") // "PORTRAIT" | "LANDSCAPE"
  logoUrl       String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([code, version])
}
