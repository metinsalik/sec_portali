generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  username              String                        @id
  fullName              String
  isActive              Boolean                       @default(true)
  employmentType        String?
  osgbName              String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  department            String?
  email                 String?
  phone                 String?
  title                 String?
  facilities            UserFacility[]
  roles                 UserRole[]
  workflowNotifications WorkflowNotificationSettings?
  workflowRole          WorkflowUserRole?
  hazmatIncidents       HazmatIncident[]
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  users     UserRole[]
}

model UserRole {
  username String
  roleId   Int
  role     Role   @relation(fields: [roleId], references: [id])
  user     User   @relation(fields: [username], references: [username])

  @@id([username, roleId])
}

model Facility {
  id                     String                      @id
  name                   String
  isActive               Boolean                     @default(true)
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  city                   String?
  commercialTitle        String?
  dangerClass            String                      @default("Az Tehlikeli")
  district               String?
  email                  String?
  employeeCount          Int                         @default(0)
  fullAddress            String?
  naceCode               String?
  phone                  String?
  sgkNumber              String?
  shortName              String?
  taxNumber              String?
  taxOffice              String?
  type                   String?
  website                String?
  logoUrl                String?                     @default("/mlpcare.jpg")
  activityLogs           ActivityLog[]
  assignments            Assignment[]
  employeeCountHistory   EmployeeCountHistory[]
  incidents              ExtraordinaryIncident[]
  buildings              FacilityBuilding[]
  monthlyAccident        MonthlyAccidentData[]
  monthlyHrData          MonthlyHRData[]
  notebookPages          NotebookPage[]
  reconciliations        Reconciliation[]
  riskCategorySettings   RiskCategorySetting[]
  riskDepartments        RiskDepartment[]
  riskDepartmentSettings RiskDepartmentSetting[]
  riskExpertFacilities   RiskExpertFacility[]
  users                  UserFacility[]
  hazmatDepartments      HazmatDepartment[]
  facilityHazmatItems    FacilityHazmatItem[]
  spillKits              HazmatSpillKit[]
  spillKitMasterItems    HazmatSpillKitMasterItem[]
  hazmatInventoryItems   HazmatInventoryItem[]
  hazmatEyewashAnalyses  HazmatEyewashRiskAnalysis[]
  hazmatIncidents        HazmatIncident[]
  fireEquipments         FireEquipment[]
  fireEquipmentLocations FireEquipmentLocation[]
}

model IncidentCategory {
  id        Int                     @id @default(autoincrement())
  name      String                  @unique
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  incidents ExtraordinaryIncident[]
}

model IncidentRootCause {
  id        Int                     @id @default(autoincrement())
  name      String                  @unique
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  incidents ExtraordinaryIncident[]
}

model IncidentSupportUnit {
  id              Int                     @id @default(autoincrement())
  name            String                  @unique
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  incidents       ExtraordinaryIncident[]
  hazmatIncidents HazmatIncident[]
}

model EmergencyCode {
  id              Int                     @id @default(autoincrement())
  name            String                  @unique
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  incidents       ExtraordinaryIncident[]
  hazmatIncidents HazmatIncident[]
}

model ExtraordinaryIncident {
  id                    Int                  @id @default(autoincrement())
  facilityId            String
  categoryId            Int
  rootCauseId           Int
  departmentId          Int
  locationDetail        String
  incidentDate          DateTime
  interventionRequired  Boolean
  interventionTime      DateTime?
  controlTime           DateTime
  supportReceived       Boolean
  supportUnitId         Int?
  announcementMade      Boolean
  emergencyCodeId       Int?
  serviceInterrupted    Boolean
  interruptionDuration  Float?
  evacuatedStaffCount   Int                  @default(0)
  evacuatedPatientCount Int                  @default(0)
  injuredCount          Int                  @default(0)
  deceasedCount         Int                  @default(0)
  summary               String
  causeDetail           String
  detectedEffect        String
  observations          String
  actionsTaken          String
  resultEvaluation      String
  createdBy             String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  attachments           Json?
  category              IncidentCategory     @relation(fields: [categoryId], references: [id])
  department            Department           @relation(fields: [departmentId], references: [id])
  emergencyCode         EmergencyCode?       @relation(fields: [emergencyCodeId], references: [id])
  facility              Facility             @relation(fields: [facilityId], references: [id])
  rootCause             IncidentRootCause    @relation(fields: [rootCauseId], references: [id])
  supportUnit           IncidentSupportUnit? @relation(fields: [supportUnitId], references: [id])

  @@index([facilityId])
}

model ActivityLog {
  id             Int           @id @default(autoincrement())
  action         String
  createdAt      DateTime      @default(now())
  details        String?
  facilityId     String
  username       String
  facility       Facility      @relation(fields: [facilityId], references: [id])
  professionalId Int?
  professional   Professional? @relation(fields: [professionalId], references: [id])
}

model EmployeeCountHistory {
  id            Int      @id @default(autoincrement())
  facilityId    String
  count         Int
  effectiveDate DateTime
  createdAt     DateTime @default(now())
  facility      Facility @relation(fields: [facilityId], references: [id])
}

model FacilityBuilding {
  id               Int      @id @default(autoincrement())
  facilityId       String
  name             String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  bedCapacity      Int?
  buildingFloors   Int?
  buildingHeight   Float?
  closedArea       Float?
  constructionYear Int?
  gardenArea       Float?
  parkingArea      Float?
  structureFloors  Int?
  structureHeight  Float?
  facility         Facility @relation(fields: [facilityId], references: [id])
}

model UserFacility {
  username   String
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id])
  user       User     @relation(fields: [username], references: [username])

  @@id([username, facilityId])
}

model Professional {
  id              Int           @id @default(autoincrement())
  fullName        String
  employmentType  String
  osgbName        String?
  titleClass      String
  certificateNo   String?
  certificateDate DateTime?
  phone           String?
  email           String?
  unitPrice       Float?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  username        String?
  assignments     Assignment[]
  activityLogs    ActivityLog[]
}

model EmployerRepresentative {
  id           Int          @id @default(autoincrement())
  fullName     String
  title        String?
  phone        String?
  email        String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  username     String?
  appointments Assignment[]
}

model OSGBCompany {
  id              Int              @id @default(autoincrement())
  name            String
  contact         String?
  phone           String?
  email           String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  city            String?
  district        String?
  reconciliations Reconciliation[]
}

model Reconciliation {
  id                 Int         @id @default(autoincrement())
  facilityId         String
  osgbCompanyId      Int
  month              String
  amount             Float?
  note               String?
  status             String      @default("Beklemede")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  calculatedAmount   Float?
  calculationDetails Json?
  difference         Float?
  invoiceAmount      Float?
  facility           Facility    @relation(fields: [facilityId], references: [id])
  osgbCompany        OSGBCompany @relation(fields: [osgbCompanyId], references: [id])

  @@unique([facilityId, osgbCompanyId, month])
}

model Assignment {
  id              Int                     @id @default(autoincrement())
  facilityId      String
  professionalId  Int?
  employerRepId   Int?
  type            String
  durationMinutes Int
  isFullTime      Boolean                 @default(false)
  startDate       DateTime
  endDate         DateTime?
  status          String
  costType        String?
  unitPrice       Float?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  employerRep     EmployerRepresentative? @relation(fields: [employerRepId], references: [id])
  facility        Facility                @relation(fields: [facilityId], references: [id])
  professional    Professional?           @relation(fields: [professionalId], references: [id])
}

model SystemSettings {
  id                  Int      @id @default(autoincrement())
  year                Int      @unique
  seriousAccidentDays Int      @default(4)
  includeSaturday     Boolean  @default(true)
  dailyWorkHours      Float    @default(7.5)
  monthlyWorkDays     Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model MonthlyHRData {
  id                Int      @id @default(autoincrement())
  facilityId        String
  month             String
  mainEmployerData  Json
  subContractorData Json
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  facility          Facility @relation(fields: [facilityId], references: [id])

  @@unique([facilityId, month])
}

model MonthlyAccidentData {
  id                Int      @id @default(autoincrement())
  facilityId        String
  month             String
  mainEmployerData  Json
  subContractorData Json
  internData        Json
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  facility          Facility @relation(fields: [facilityId], references: [id])

  @@unique([facilityId, month])
}

model Category {
  id            Int            @id @default(autoincrement())
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notebookItems NotebookItem[]
  subCategories SubCategory[]
}

model SubCategory {
  id            Int            @id @default(autoincrement())
  name          String
  categoryId    Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notebookItems NotebookItem[]
  category      Category       @relation(fields: [categoryId], references: [id])
}

model Department {
  id            Int                     @id @default(autoincrement())
  name          String
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  incidents     ExtraordinaryIncident[]
  notebookItems NotebookItem[]
}

model NotebookPage {
  id                 Int            @id @default(autoincrement())
  facilityId         String
  year               Int
  date               DateTime
  documentUrl        String?
  status             String         @default("Eksik")
  createdBy          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  documentUploadedAt DateTime?
  isArchived         Boolean        @default(false)
  isLocked           Boolean        @default(false)
  items              NotebookItem[]
  facility           Facility       @relation(fields: [facilityId], references: [id])

  @@index([facilityId, year])
}

model NotebookItem {
  id            Int          @id @default(autoincrement())
  pageId        Int
  authorType    String
  authorName    String
  content       String
  categoryId    Int
  subCategoryId Int?
  departmentId  Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  category      Category     @relation(fields: [categoryId], references: [id])
  department    Department   @relation(fields: [departmentId], references: [id])
  page          NotebookPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
}

model SmtpSettings {
  id        Int      @id @default(1)
  host      String
  port      Int
  user      String
  pass      String
  secure    Boolean  @default(false)
  fromEmail String
  fromName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id         Int      @id @default(autoincrement())
  title      String
  message    String
  type       String
  module     String   @default("SYSTEM")
  targetRole String?
  username   String?
  isRead     Boolean  @default(false)
  link       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model NotificationTemplate {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  module    String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationConfig {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  module       String
  description  String?
  emailEnabled Boolean  @default(true)
  appEnabled   Boolean  @default(true)
  priority     String   @default("normal")
  updatedAt    DateTime @updatedAt
}

model AdministrativeFine {
  id                           Int      @id @default(autoincrement())
  year                         Int      @unique
  specialistAndPhysicianVery   Float
  specialistAndPhysicianDanger Float
  specialistAndPhysicianLess   Float
  dspVeryDangerous             Float
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model ReportTemplate {
  id          Int       @id @default(autoincrement())
  code        String
  name        String
  version     Int       @default(1)
  isActive    Boolean   @default(false)
  isArchived  Boolean   @default(false)
  module      String
  documentNo  String?
  revisionNo  String?
  releaseDate DateTime?
  content     Json
  orientation String    @default("PORTRAIT")
  logoUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([code, version])
}

model WorkflowDepartment {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  managerId   String?
  createdAt   DateTime           @default(now())
  tasks       WorkflowTask[]
  roles       WorkflowUserRole[]
}

model WorkflowUserRole {
  id           Int                 @id @default(autoincrement())
  userId       String              @unique
  moduleRole   String
  departmentId Int?
  reportsTo    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  department   WorkflowDepartment? @relation(fields: [departmentId], references: [id])
  user         User                @relation(fields: [userId], references: [username])
}

model WorkflowCategory {
  id        Int            @id @default(autoincrement())
  name      String
  color     String?
  icon      String?
  createdAt DateTime       @default(now())
  tasks     WorkflowTask[]
}

model WorkflowTag {
  id    Int               @id @default(autoincrement())
  name  String
  color String?
  tasks WorkflowTaskTag[]
}

model WorkflowTask {
  id           Int                      @id @default(autoincrement())
  title        String
  description  String?
  priority     String                   @default("MEDIUM")
  status       String                   @default("BEKLIYOR")
  categoryId   Int?
  departmentId Int?
  createdBy    String
  dueDate      DateTime?
  alarmDate    DateTime?
  isPool       Boolean                  @default(false)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  alarms       WorkflowAlarm[]
  category     WorkflowCategory?        @relation(fields: [categoryId], references: [id])
  department   WorkflowDepartment?      @relation(fields: [departmentId], references: [id])
  assignments  WorkflowTaskAssignment[]
  comments     WorkflowTaskComment[]
  history      WorkflowTaskHistory[]
  tags         WorkflowTaskTag[]
}

model WorkflowTaskTag {
  taskId Int
  tagId  Int
  tag    WorkflowTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  task   WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model WorkflowTaskAssignment {
  id          Int          @id @default(autoincrement())
  taskId      Int
  userId      String
  role        String       @default("ASSIGNEE")
  assignedBy  String
  assignedAt  DateTime     @default(now())
  completedAt DateTime?
  task        WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model WorkflowTaskHistory {
  id        Int          @id @default(autoincrement())
  taskId    Int
  changedBy String
  oldStatus String?
  newStatus String?
  note      String?
  changedAt DateTime     @default(now())
  task      WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model WorkflowTaskComment {
  id        Int          @id @default(autoincrement())
  taskId    Int
  userId    String
  content   String
  createdAt DateTime     @default(now())
  task      WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model WorkflowAlarm {
  id        Int          @id @default(autoincrement())
  taskId    Int
  alarmDate DateTime
  alarmType String
  isSent    Boolean      @default(false)
  sentAt    DateTime?
  createdBy String
  task      WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model WorkflowNotificationSettings {
  id                   Int      @id @default(autoincrement())
  userId               String   @unique
  telegramChatId       String?
  whatsappNumber       String?
  notifyOnAssign       Boolean  @default(true)
  notifyOnStatusChange Boolean  @default(true)
  notifyOnAlarm        Boolean  @default(true)
  notifyOnComment      Boolean  @default(true)
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [username])
}

model RiskExpertFacility {
  expertUsername String
  facilityId     String
  facility       Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([expertUsername, facilityId])
}

model RiskDepartment {
  id         Int                  @id @default(autoincrement())
  facilityId String
  name       String
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  code       String?
  facility   Facility             @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  risks      RiskLifecycle[]
  areas      RiskDepartmentArea[]

  @@unique([facilityId, name])
}

model RiskDepartmentArea {
  id           Int            @id @default(autoincrement())
  name         String
  departmentId Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  department   RiskDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, name])
}

model RiskLifecycle {
  id                         String         @id @default(uuid())
  departmentId               Int
  riskNo                     Int
  riskCategory               String
  subCategory                String?
  area                       String
  method                     String         @default("Fine Kinney")
  activity                   String
  hazard                     String
  riskDescription            String
  initialCondition           String?
  initialImage               String?
  initialProb                Float
  initialFreq                Float?
  initialSev                 Float
  initialScore               Float
  initialLevel               String
  firstActionPlan            String?
  actionsTaken               String?
  actionDate                 DateTime?
  actionBy                   String?
  actionImage                String?
  followUpMeasure            String?
  extraImprovement           String?
  finalProb                  Float?
  finalFreq                  Float?
  finalSev                   Float?
  finalScore                 Float?
  finalLevel                 String?
  status                     String         @default("ACIK_TEHLIKE")
  createdBy                  String?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  affectedPeople             String?
  controlResponsible         String?
  controlResult              String?
  detectionDate              DateTime?
  dueDate                    DateTime?
  effectivenessMethod        String?
  impactDamage               String?
  improvementResponsible     String?
  legislation                String?
  postImprovementDueDate     DateTime?
  dueDatePeriod              String?
  postImprovementResponsible String?
  auditLogs                  RiskAuditLog[]
  department                 RiskDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([departmentId])
}

model RiskAuditLog {
  id            String        @id @default(uuid())
  riskId        String
  action        String
  details       String?
  changedFields Json?
  username      String
  createdAt     DateTime      @default(now())
  risk          RiskLifecycle @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@index([riskId])
}

model RiskDepartmentSetting {
  id         Int      @id @default(autoincrement())
  facilityId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([facilityId, name])
}

model RiskCategorySetting {
  id            Int                      @id @default(autoincrement())
  facilityId    String
  name          String
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  facility      Facility                 @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  subCategories RiskSubCategorySetting[]

  @@unique([facilityId, name])
}

model RiskSubCategorySetting {
  id         Int                 @id @default(autoincrement())
  name       String
  categoryId Int
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  category   RiskCategorySetting @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
}

model HazmatUnit {
  id            String               @id @default(cuid())
  name          String
  symbol        String
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  facilityItems FacilityHazmatItem[]
}

model HazmatHazardLabel {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materials HazmatMaterialHazardLabel[]
}

model HazmatAdrLabel {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materials HazmatMaterialAdrLabel[]
}

model HazmatPpe {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materials HazmatMaterialPpe[]
}

model HazmatCategory {
  id        String   @id @default(uuid())
  name      String
  scope     String?
  examples  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materials       HazmatMaterial[]
  hazmatIncidents HazmatIncident[]
}

model HazmatMaterial {
  id                            String                      @id @default(uuid())
  productName                   String
  brandName                     String?
  usageMethod                   String?
  composition                   String?
  hazardDescription             String?
  firstAid                      String?
  fireFightingMeasures          String?
  accidentalReleaseMeasures     String?
  handlingAndStorage            String?
  exposureControlsPpe           String?
  physicalAndChemicalProperties String?
  stabilityAndReactivity        String?
  toxicologicalInformation      String?
  ecologicalInformation         String?
  disposalConsiderations        String?
  transportInfo                 String?
  regulatoryInfo                String?
  imageUrl                      String?
  sdsUrl                        String?
  sdsExpiryDate                 DateTime?
  categoryId                    String?
  category                      HazmatCategory?             @relation(fields: [categoryId], references: [id])
  isActive                      Boolean                     @default(true)
  createdAt                     DateTime                    @default(now())
  updatedAt                     DateTime                    @updatedAt
  hazardLabels                  HazmatMaterialHazardLabel[]
  adrLabels                     HazmatMaterialAdrLabel[]
  ppes                          HazmatMaterialPpe[]
  facilityItems                 FacilityHazmatItem[]
  inventory                     HazmatInventoryItem[]
  auditLogs                     HazmatAuditLog[]
  hazmatIncidents               HazmatIncident[]
}

model HazmatMaterialHazardLabel {
  id         String            @id @default(uuid())
  materialId String
  labelId    String
  material   HazmatMaterial    @relation(fields: [materialId], references: [id], onDelete: Cascade)
  label      HazmatHazardLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([materialId, labelId])
}

model HazmatMaterialAdrLabel {
  id         String         @id @default(uuid())
  materialId String
  labelId    String
  material   HazmatMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  label      HazmatAdrLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([materialId, labelId])
}

model HazmatMaterialPpe {
  id         String         @id @default(uuid())
  materialId String
  ppeId      String
  material   HazmatMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  ppe        HazmatPpe      @relation(fields: [ppeId], references: [id], onDelete: Cascade)

  @@unique([materialId, ppeId])
}

model HazmatDepartment {
  id              String                @id @default(uuid())
  facilityId      String
  facility        Facility              @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  name            String
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  inventory       HazmatInventoryItem[]
  hazmatIncidents HazmatIncident[]
}

model FacilityHazmatItem {
  id          String   @id @default(uuid())
  facilityId  String
  materialId  String
  amountValue Float?
  unitId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facility Facility       @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  material HazmatMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  unit     HazmatUnit?    @relation(fields: [unitId], references: [id])

  @@unique([facilityId, materialId])
}

model HazmatInventoryItem {
  id           String           @id @default(uuid())
  facilityId   String
  departmentId String
  materialId   String
  minQuantity  Float?
  maxQuantity  Float?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  facility     Facility         @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  department   HazmatDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  material     HazmatMaterial   @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([facilityId, departmentId, materialId])
  @@index([facilityId, departmentId])
  @@index([facilityId, materialId])
}

model HazmatAuditLog {
  id            String         @id @default(uuid())
  materialId    String
  action        String
  details       String?
  changedFields Json?
  username      String
  createdAt     DateTime       @default(now())
  material      HazmatMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId])
}

model HazmatSpillKit {
  id         String   @id @default(uuid())
  code       String? // Auto-generated like DCK-001
  facilityId String
  purpose    String
  risk       String   @default("Orta")
  kitName    String
  needReason String?
  worstCase  String?
  period     Int      @default(30)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items      HazmatSpillKitItem[]
  placements HazmatSpillKitDepartment[]

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
}

model HazmatSpillKitItem {
  id        String   @id @default(uuid())
  kitId     String
  name      String
  type      String?
  qty       Int      @default(0)
  min       Int      @default(0)
  exp       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kit HazmatSpillKit @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@index([kitId])
}

model HazmatSpillKitDepartment {
  id          String   @id @default(uuid())
  kitId       String
  unit        String
  area        String?
  location    String?
  owner       String?
  backupOwner String?
  visible     Boolean  @default(false)
  sign        Boolean  @default(false)
  instruction Boolean  @default(false)
  training    Boolean  @default(false)
  note        String?
  status      String   @default("Kurulumda")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kit       HazmatSpillKit           @relation(fields: [kitId], references: [id], onDelete: Cascade)
  checks    HazmatSpillKitCheck[]
  incidents HazmatSpillKitIncident[]
  actions   HazmatSpillKitAction[]

  @@index([kitId])
}

model HazmatSpillKitCheck {
  id          String    @id @default(uuid())
  placementId String
  lastCheck   DateTime?
  period      Int       @default(30)
  result      String    @default("Kontrol Edilmedi")
  checkedBy   String?
  contentOk   Boolean   @default(false)
  expiryOk    Boolean   @default(false)
  qtyOk       Boolean   @default(false)
  packageOk   Boolean   @default(false)
  note        String?
  itemChecks  Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  placement HazmatSpillKitDepartment @relation(fields: [placementId], references: [id], onDelete: Cascade)

  @@index([placementId])
}

model HazmatSpillKitIncident {
  id              String    @id @default(uuid())
  placementId     String
  incidentDate    DateTime?
  incidentType    String?
  kitUsed         String?
  incidentDesc    String?
  usedItems       String?
  incidentOutcome String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  placement HazmatSpillKitDepartment @relation(fields: [placementId], references: [id], onDelete: Cascade)

  @@index([placementId])
}

model HazmatSpillKitAction {
  id          String    @id @default(uuid())
  placementId String
  actionType  String?
  owner       String?
  dueDate     DateTime?
  description String?
  status      String    @default("Açık")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  placement HazmatSpillKitDepartment @relation(fields: [placementId], references: [id], onDelete: Cascade)

  @@index([placementId])
}

model HazmatSpillKitMasterItem {
  id         String   @id @default(uuid())
  facilityId String
  name       String
  type       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
}

model HazmatEyewashRiskAnalysis {
  id               String   @id @default(uuid())
  facilityId       String
  analysisDate     DateTime
  department       String
  areaSquareMeters Float
  maxPersonnel     Int

  chemicalDetails     Json?
  chemicalTotalLiters Float @default(0)

  chemExposureCount Int @default(0)
  chemNearMissCount Int @default(0)
  bioExposureCount  Int @default(0)
  bioNearMissCount  Int @default(0)

  chemProbability Float   @default(0)
  chemFrequency   Float   @default(0)
  chemSeverity    Float   @default(0)
  chemScore       Float   @default(0)
  chemRiskLevel   String?

  bioProbability Float   @default(0)
  bioFrequency   Float   @default(0)
  bioSeverity    Float   @default(0)
  bioScore       Float   @default(0)
  bioRiskLevel   String?

  evaluationNotes         String?
  eyewashRequirementLevel String?
  actionPlan              String?

  improvementDescription String?
  improvementTargetDate  DateTime?
  improvementImageUrl    String?
  effectivenessMethod    String?
  improvementController  String?
  improvementResult      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
}

model HazmatIncident {
  id                    String    @id @default(uuid())
  facilityId            String
  categoryId            String
  rootCause             String
  departmentId          String
  incidentDate          DateTime
  interventionRequired  Boolean
  interventionTime      DateTime?
  controlTime           DateTime
  supportReceived       Boolean
  supportUnitId         Int?
  announcementMade      Boolean
  emergencyCodeId       Int?
  serviceInterrupted    Boolean
  interruptionDuration  Float?
  evacuatedStaffCount   Int       @default(0)
  evacuatedPatientCount Int       @default(0)
  injuredCount          Int       @default(0)
  deceasedCount         Int       @default(0)
  incidentMode          String
  causeDetail           String
  detectedEffect        String
  observations          String
  actionsTaken          String
  resultEvaluation      String
  kitUsed               Boolean   @default(false)
  spillKitId            String?
  createdBy             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  category      HazmatCategory       @relation(fields: [categoryId], references: [id])
  supportUnit   IncidentSupportUnit? @relation(fields: [supportUnitId], references: [id])
  emergencyCode EmergencyCode?       @relation(fields: [emergencyCodeId], references: [id])
  facility      Facility             @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  department    HazmatDepartment     @relation(fields: [departmentId], references: [id])
  creator       User?                @relation(fields: [createdBy], references: [username])
  materials     HazmatMaterial[]

  @@index([facilityId])
}

// --- FIRE EQUIPMENT MODULE (FireTrack 360) ---

model FireEquipmentCategory {
  id                   String   @id @default(uuid())
  name                 String // Yangın Tüpü, Yangın Dolabı, vb.
  description          String?
  parentId             String? // Alt kategori ise üst kategorinin ID'si
  maintenanceFrequency String? // 'AYLIK', '3_AYLIK', '6_AYLIK', 'YILLIK'
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  parent        FireEquipmentCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subcategories FireEquipmentCategory[] @relation("CategoryHierarchy")
  equipments    FireEquipment[]
}

model FireEquipmentLocation {
  id          String   @id @default(uuid())
  facilityId  String
  building    String? // Bina
  block       String? // Blok
  floor       String? // Kat
  department  String? // Bölüm
  description String? // Konum Açıklaması
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facility   Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  equipments FireEquipment[]

  @@index([facilityId])
}

model FireEquipmentResponsible {
  id         String   @id @default(uuid())
  facilityId String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  facility   Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  equipments FireEquipment[]

  @@index([facilityId])
}

model FireEquipment {
  id             String  @id @default(uuid())
  equipmentNo    String  @unique // Ekipman No
  qrCode         String? @unique // Barkod / QR Kod
  serialNo       String? // Seri No
  brand          String? // Marka
  model          String? // Model
  productionYear Int? // Üretim Yılı

  categoryId    String
  locationId    String?
  facilityId    String
  responsibleId String? // Sorumlu Kişi ID'si

  capacity        String? // Kapasite (Örn: 6kg)
  standard        String? // Standart
  criticality     String? // Kritiklik Seviyesi (Düşük, Orta, Yüksek)
  responsibleUnit String? // Sorumlu Birim (Opsiyonel, metin olarak kalabilir)

  status String @default("AKTIF") // AKTIF, DEGISIME_GIDEN, ARIZALI, HURDA, KULLANIM_DISI, DEPODA

  nextMaintenanceDate DateTime? // Sonraki Bakım Tarihi

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category    FireEquipmentCategory     @relation(fields: [categoryId], references: [id])
  location    FireEquipmentLocation?    @relation(fields: [locationId], references: [id])
  facility    Facility                  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  responsible FireEquipmentResponsible? @relation(fields: [responsibleId], references: [id], onDelete: SetNull)

  movements    FireEquipmentMovement[]
  maintenances FireEquipmentMaintenance[]

  @@index([facilityId])
}

model FireEquipmentMovement {
  id            String   @id @default(uuid())
  equipmentId   String
  oldLocationId String?
  newLocationId String?
  reason        String?
  movedBy       String // İşlemi Yapan Kişi (username)
  description   String?
  movementDate  DateTime @default(now())

  equipment FireEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
}

model FireEquipmentMaintenance {
  id              String   @id @default(uuid())
  equipmentId     String
  maintenanceDate DateTime
  company         String? // Firma
  technician      String? // Teknisyen
  result          String // UYGUN, SARTLI_UYGUN, UYGUN_DEGIL
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  equipment FireEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
}
