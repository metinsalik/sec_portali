  updatedAt   DateTime @updatedAt

  facility Facility       @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  projects BuildProject[]
}

model BuildContractor {
  id          String   @id @default(uuid())
  facilityId  String
  name        String
  contactName String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facility Facility       @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  projects BuildProject[]
}

model BuildWorkType {
  id          String   @id @default(uuid())
  facilityId  String
  name        String // Renovasyon, İnşaat, Yıkım vb.
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facility Facility       @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  projects BuildProject[]
}

model BuildProject {
  id               String    @id @default(uuid())
  facilityId       String
  name             String
  locationId       String?
  workTypeId       String?
  contractorId     String?
  buildType        String? // A, B, C, D
  riskGroup        String? // 1, 2, 3, 4
  icraClass        String? // Sınıf I, II, III, IV (Otomatik)
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  projectManager   String?
  description      String?
  status           String    @default("Başlatılmaz") // Başlatılmaz, İş Başlayabilir, Devam Ediyor, Durduruldu, Teslim Bekliyor, Tamamlandı, Arşivlendi
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdById      String?

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  creator  User?    @relation(fields: [createdById], references: [username])

  location   BuildLocation?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  workType   BuildWorkType?   @relation(fields: [workTypeId], references: [id], onDelete: SetNull)
  contractor BuildContractor? @relation(fields: [contractorId], references: [id], onDelete: SetNull)

  designForm                   BuildDesignForm?
  riskAssessment               BuildRiskAssessment?
  icra                         BuildICRA?
  approvals                    BuildApproval[]
  permits                      BuildPermit[]
  inspectionsOHS               BuildInspectionOHS[]
  inspectionsInfection         BuildInspectionInfection[]
  handoverOHSInspections       BuildHandoverOHSInspection[]
  handoverInfectionInspections BuildHandoverInfectionInspection[]
  findings                     BuildFinding[]
  documents                    BuildDocument[]
  handover                     BuildHandover?
  BuildAction                  BuildAction[]

  @@index([facilityId])
}

model BuildDesignForm {
  id                  String   @id @default(uuid())
  projectId           String   @unique
  formType            String // Tasarım, Geliştirme, Tasarım ve Geliştirme
  formDate            DateTime
  description         String?
  requester           String?
  projectSponsor      String?
  notes               String?
  relatedDepartments  String?
  projectManager      String?
  otherTeamMembers    String?
  projectGoal         String?
  projectPlan         String?
  inputs              String?
  outputs             String?
  verification        String?
  review              String?
  validityCheck       String?
  validityStudies     String?
  postServiceValidity String?
  changeControl       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project BuildProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BuildRiskAssessment {
  id                   String   @id @default(uuid())
  projectId            String   @unique
  patientCareProximity Boolean  @default(false)
  dustNoiseVibration   Boolean  @default(false)
  criticalAreaAffected Boolean  @default(false)
  hvacAffected         Boolean  @default(false)
  medicalGasAffected   Boolean  @default(false)
  fireSafetyAffected   Boolean  @default(false)
  powerOutageRisk      Boolean  @default(false)
  waterLeakRisk        Boolean  @default(false)
  likelihood           Int      @default(0) // 5x5 matris için olasılık (1-5)
  severity             Int      @default(0) // 5x5 matris için şiddet (1-5)
  riskScore            Int      @default(0)
  riskLevel            String   @default("Düşük Risk") // Düşük, Orta, Yüksek, Kritik
  patientSafetyNotes   String?
  infectionNotes       String?
  fireSafetyNotes      String?
  infrastructureNotes  String?
  ohsNotes             String?
  matrixData           Json? // 10 kategorilik 5x5 PCRA değerlendirme tablosu verileri
  contractorCompliance String? // Yüklenici uyumu ve takip dokümantasyonu notları
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  project BuildProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BuildICRA {
  id              String   @id @default(uuid())
  projectId       String   @unique
  calculatedClass String // Sınıf I, II, III, IV
  precautions     Json? // Sınıfa göre otomatik gelen maddelerin listesi
  customNotes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project BuildProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
