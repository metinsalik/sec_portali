model BuildApproval {
  id           String    @id @default(uuid())
  projectId    String
  approvalType String // Teknik Hizmetler, İSG, Enfeksiyon Kontrol, Yangın Güvenliği, Klinik Birim vb.
  status       String    @default("Bekliyor") // Bekliyor, Onaylandı, Reddedildi
  approvedBy   String? // Username
  approvedAt   DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project  BuildProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
