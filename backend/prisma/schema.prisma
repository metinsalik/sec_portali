// --- FIRE EQUIPMENT MODULE (FireTrack 360) ---

model FireEquipmentCategory {
  id                    String   @id @default(uuid())
  name                  String // Yangın Tüpü, Yangın Dolabı, vb.
  description           String?
  parentId              String? // Alt kategori ise üst kategorinin ID'si
  maintenanceFrequency  String? // 'AYLIK', '3_AYLIK', '6_AYLIK', 'YILLIK'
  inventoryParameters   Json? // Dinamik envanter şeması
  maintenanceParameters Json? // Dinamik bakım şeması
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  parent        FireEquipmentCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subcategories FireEquipmentCategory[] @relation("CategoryHierarchy")
  equipments    FireEquipment[]
}

model FireEquipmentResponsible {
  id         String   @id @default(uuid())
  facilityId String
  department String? // Departman
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  facility   Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  equipments FireEquipment[]

  @@index([facilityId])
}

model FireEquipmentCompany {
  id         String   @id @default(uuid())
  facilityId String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  facility     Facility                   @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  equipments   FireEquipment[]
  maintenances FireEquipmentMaintenance[]

  @@index([facilityId])
}

model FireEquipment {
  id             String    @id @default(uuid())
  equipmentNo    String // Ekipman No (tesis bazında benzersiz)
  qrCode         String? // Barkod / QR Kod (tesis bazında benzersiz)
  serialNo       String? // Seri No
  brand          String? // Marka
  model          String? // Model
  productionDate DateTime? // Üretim Tarihi

  categoryId    String
  locationId    String?
  facilityId    String
  responsibleId String? // Sorumlu Kişi ID'si
  companyId     String? // Firma ID'si

  capacity        String? // Kapasite (Örn: 6kg)
  standard        String? // Standart
  criticality     String? // Kritiklik Seviyesi (Düşük, Orta, Yüksek)
  responsibleUnit String? // Sorumlu Birim (Opsiyonel, metin olarak kalabilir)
  inventoryData   Json? // Dinamik envanter özellikleri

  status String @default("AKTIF") // AKTIF, DEGISIME_GIDEN, ARIZALI, HURDA, KULLANIM_DISI, DEPODA

  nextMaintenanceDate DateTime? // Sonraki Bakım Tarihi

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notes     String?

  category    FireEquipmentCategory     @relation(fields: [categoryId], references: [id])
  location    HazmatDepartment?         @relation(fields: [locationId], references: [id])
  facility    Facility                  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  responsible FireEquipmentResponsible? @relation(fields: [responsibleId], references: [id], onDelete: SetNull)
  company     FireEquipmentCompany?     @relation(fields: [companyId], references: [id], onDelete: SetNull)

  movements    FireEquipmentMovement[]
  maintenances FireEquipmentMaintenance[]

  @@unique([facilityId, equipmentNo])
  @@unique([facilityId, qrCode])
  @@index([facilityId])
}

model FireEquipmentMovement {
  id            String   @id @default(uuid())
  equipmentId   String
  oldLocationId String?
  newLocationId String?
  reason        String?
  movedBy       String // İşlemi Yapan Kişi (username)
  description   String?
  movementDate  DateTime @default(now())

  equipment FireEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
}

model FireEquipmentMaintenance {
  id              String   @id @default(uuid())
  equipmentId     String
  maintenanceDate DateTime
  companyId       String? // Yeni Company ilişkisi
  company         String? // Firma (Legacy)
  technician      String? // Teknisyen
  result          String // UYGUN, SARTLI_UYGUN, UYGUN_DEGIL
  description     String?
  maintenanceData Json? // Dinamik bakım özellikleri
  attachmentUrl   String? // Yüklenen fotoğraf/belge yolu
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  equipment  FireEquipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  companyRel FireEquipmentCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
}

// --- BUILD MANAGEMENT MODULE ---

model BuildLocation {
  id          String   @id @default(uuid())
  facilityId  String
  block       String? // Blok
